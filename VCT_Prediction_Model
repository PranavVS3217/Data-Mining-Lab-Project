\n","master = pd.read_csv(Path(OUTPUT_PATH, 'master_dataset.csv'))\n","\n","# Load all 3 ensemble models\n","ensemble_pipes = {}\n","for mname in ['XGBoost', 'LightGBM', 'CatBoost']:\n","    fname = mname.replace(' ', '_')\n","    with open(Path(OUTPUT_PATH, 'models', f'{fname}.pkl'), 'rb') as f:\n","        ensemble_pipes[mname] = pickle.load(f)\n","\n","# Fit CatBoost imputer on training data\n","cat_imputer = SimpleImputer(strategy='median')\n","cat_imputer.fit(master[FEATURE_COLS].fillna(master[FEATURE_COLS].median()))\n","\n","# Load map encoder from master\n","from sklearn.preprocessing import LabelEncoder\n","map_encoder = LabelEncoder()\n","map_encoder.fit(master['Map'].dropna().unique())\n","\n","# All known agents (from your dataset)\n","KNOWN_AGENTS = sorted([\n","    'astra', 'breach', 'brimstone', 'chamber', 'clove', 'cypher',\n","    'deadlock', 'fade', 'gekko', 'harbor', 'iso', 'jett', 'kayo',\n","    'killjoy', 'neon', 'omen', 'phoenix', 'raze', 'reyna', 'sage',\n","    'skye', 'sova', 'tejo', 'viper', 'violation', 'vyse', 'waylay',\n","    'yoru'\n","])\n","\n","KNOWN_MAPS = sorted(master['Map'].dropna().unique().tolist())\n","\n","print('Models and data loaded')\n","print(f'Known maps: {KNOWN_MAPS}')\n","print(f'Known agents ({len(KNOWN_AGENTS)}): {KNOWN_AGENTS}')"],"metadata":{"id":"qC1l7gsLtGXs","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776710266472,"user_tz":-330,"elapsed":1111,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"b22cbd05-f16a-4369-a294-43c4a610e8ae"},"id":"qC1l7gsLtGXs","execution_count":22,"outputs":[{"output_type":"stream","name":"stdout","text":["Models and data loaded\n","Known maps: ['Abyss', 'Ascent', 'Bind', 'Breeze', 'Corrode', 'Fracture', 'Haven', 'Icebox', 'Lotus', 'Pearl', 'Split', 'Sunset']\n","Known agents (28): ['astra', 'breach', 'brimstone', 'chamber', 'clove', 'cypher', 'deadlock', 'fade', 'gekko', 'harbor', 'iso', 'jett', 'kayo', 'kil