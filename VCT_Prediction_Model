rue\n"]}]},{"cell_type":"markdown","source":["# Cell 19 - Prediction"],"metadata":{"id":"dSth0DgEtR7K"},"id":"dSth0DgEtR7K"},{"cell_type":"code","source":["# ── Feature builder ───────────────────────────────────────────\n","\n","def get_team_state(team, opponent, map_name):\n","    \"\"\"\n","    Extracts the team's most recent feature state from master dataset.\n","    Returns a dict of feature values representing going INTO the next match.\n","    \"\"\"\n","    team_rows = master[master['Team'] == team].sort_values('_year_int')\n","    map_rows  = team_rows[team_rows['Map'] == map_name]\n","    h2h_rows  = team_rows[team_rows['Opponent'] == opponent]\n","\n","    last     = team_rows.iloc[-1].to_dict() if len(team_rows) > 0 else {}\n","    last_map = map_rows.iloc[-1].to_dict()  if len(map_rows)  > 0 else {}\n","\n","    return {\n","        '_year_int'           : 2025,\n","        'is_playoffs'         : int(IS_PLAYOFF),\n","        'team_rolling_wr_10'  : last.get('team_rolling_wr_10',  np.nan),\n","        'team_rolling_wr_5'   : last.get('team_rolling_wr_5',   np.nan),\n","        'team_rolling_wr_20'  : last.get('team_rolling_wr_20',  np.nan),\n","        'team_win_streak'     : last.get('team_win_streak',     0),\n","        'map_specific_wr'     : map_rows['win'].mean() if len(map_rows) > 0 else np.nan,\n","        'team_map_wins'       : last_map.get('team_map_wins',        np.nan),\n","        'team_map_losses'     : last_map.get('team_map_losses',      np.nan),\n","        'team_map_wr_hist'    : last_map.get('team_map_wr_hist',     np.nan),\n","        'team_map_total_played': last_map.get('team_map_total_played', np.nan),\n","        'h2h_win_rate'        : h2h_rows['win'].mean() if len(h2h_rows) > 0 else np.nan,\n","        'elo'                 : last.get('elo',  1000.0),\n","        'hist_avg_acs'        : last.get('hist_avg_acs',  np.nan),\n","        'hist_avg_kd'         : last.get('hist_avg_kd',   np.nan),\n","        'hist_avg_adr'        : last.get('hist_avg_adr',  np.nan),\n","        'hist_avg_kast'       : last.get('hist_avg_kast', np.nan),\n","        'hist_avg_hs'         : last.get('hist_avg_hs',   np.nan),\n","        'hist_fk_diff'        : last.get('hist_fk_diff',  np.nan),\n","        'hist_first_kill_rate': last.get('hist_first_kill_rate', np.nan),\n","        'ban_rate'            : last_map.get('ban_rate',          np.nan),\n","        'pick_rate'           : last_map.get('pick_rate',         np.nan),\n","        'map_preference'      : last_map.get('map_preference',    np.nan),\n","    }\n","\n","\n","def compute_agent_meta_score(agents, map_name, year='vct_2025'):\n","    \"\"\"\n","    Computes meta score from the ACTUAL agents entered by user.\n","    Uses agents_pick from master dataset to find pick rates.\n","    \"\"\"\n","    # Get pick rates for these specific agents in this year\n","    ap_year = agents_pick[agents_pick['_year'] == year].copy() if 'agents_pick' in dir() else None\n","\n","    # Fallback: use meta from master dataset agent meta scores\n","    map_meta = master[(master['Map'] == map_name) &\n","                      (master['_year'] == year)]['meta_score']\n","    base_meta = map_meta.mean() if len(map_meta) > 0 else np.nan\n","\n","    # Try to get actual pick rates from agents_pick table\n","    try:\n","        ap_filtered = agents_pick[\n","            (agents_pick['_year'] == year) &\n","            (agents_pick['Map'] == 'All Maps') &\n","            (agents_pick['Agent'].str.lower().isin(agents))\n","        ]\n","        if len(ap_filtered) > 0 and 'Pick Rate' in ap_filtered.columns:\n","            pick_rates = ap_filtered.groupby('Agent')['Pick Rate'].mean()\n","            meta_score = pick_rates.mean()\n","            return meta_score, len(set(agents))\n","    except Exception:\n","        pass\n","\n","    return base_meta, len(set(agents))\n","\n","\n","def build_feature_row(team, opponent, map_name, agents_team, agents_opp):\n","    \"\"\"\n","    Builds a single feature row for prediction.\n","    \"\"\"\n","    state_team = get_team_state(team, opponent, map_name)\n","    state_opp  = get_team_state(opponent, team, map_name)\n","\n","    # Agent-based meta score (uses actual agents input by user)\n","    meta_score_team, diversity_team = compute_agent_meta_score(agents_team, map_name)\n","    meta_score_opp,  diversity_opp  = compute_agent_meta_score(agents_opp,  map_name)\n","\n","    # Map encoding\n","    try:\n","        map_enc = map_encoder.transform([map_name])[0]\n","    except ValueError:\n","        map_enc = 0\n","\n","    row = {\n","        'map_encoded'          : map_enc,\n","        '_year_int'            : state_team['_year_int'],\n","        'is_playoffs'          : state_team['is_playoffs'],\n","        'team_rolling_wr_10'   : state_team['team_rolling_wr_10'],\n","        'team_rolling_wr_5'    : state_team['team_rolling_wr_5'],\n","        'team_rolling_wr_20'   : state_team['team_rolling_wr_20'],\n","        'team_win_streak'      : state_team['team_win_streak'],\n","        'opp_rolling_wr_10'    : state_opp['team_rolling_wr_10'],\n","        'wr_diff'              : (state_team['team_rolling_wr_10'] or 0.5) -\n","                                 (state_opp['team_rolling_wr_10']  or 0.5),\n","        'h2h_win_rate'         : state_team['h2h_win_rate'],\n","        'map_specific_wr'      : state_team['map_specific_wr'],\n","        'team_map_wins'        : state_team['team_map_wins'],\n","        'team_map_losses'      : state_team['team_map_losses'],\n","        'team_map_wr_hist'     : state_team['team_map_wr_hist'],\n","        'team_map_total_played': state_team['team_map_total_played'],\n","        'elo'                  : state_team['elo'],\n","        'opp_elo'              : state_opp['elo'],\n","        'elo_diff'             : state_team['elo'] - state_opp['elo'],\n","        'meta_score'           : meta_score_team,   # ← from actual agents input\n","        'agent_diversity'      : diversity_team,     # ← from actual agents input\n","        'ban_rate'             : state_team['ban_rate'],\n","        'pick_rate'            : state_team['pick_rate'],\n","        'map_preference'       : state_team['map_preference'],\n","        'opp_map_preference'   : state_opp['map_preference'],\n","        'map_preference_diff'  : (state_team['map_preference'] or 0) -\n","                                 (state_opp['map_preference']  or 0),\n","        'hist_avg_acs'         : state_team['hist_avg_acs'],\n","        'hist_avg_kd'          : state_team['hist_avg_kd'],\n","        'hist_avg_adr'         : state_team['hist_avg_adr'],\n","        'hist_avg_kast'        : state_team['hist_avg_kast'],\n","        'hist_avg_hs'          : state_team['hist_avg_hs'],\n","        'hist_fk_diff'         : state_team['hist_fk_diff'],\n","        'hist_first_kill_rate' : state_team['hist_first_kill_rate'],\n","    }\n","\n","    # Keep only feature cols that exist\n","    return pd.DataFrame([{k: row.get(k, np.nan) for k in FEATURE_COLS}])\n","\n","\n","def predict_map_winner(team_a, team_b, map_name, agents_a, agents_b):\n","    \"\"\"\n","    Main prediction function.\n","    Returns win probability for Team A.\n","    \"\"\"\n","    row_a = build_feature_row(team_a, team_b, map_name, agents_a, agents_b)\n","\n","    probs = []\n","    for mname, pipe in ensemble_pipes.items():\n","        if mname == 'CatBoost':\n","            p = pipe.predict_proba(cat_imputer.transform(row_a))[:,1][0]\n","        else:\n","            p = pipe.predict_proba(row_a)[:,1][0]\n","        probs.append(p)\n","\n","    prob_a = float(np.mean(probs))\n","    prob_b = 1 - prob_a\n","    return prob_a, prob_b\n","\n","\n","def confidence_label(prob):\n","    if prob >= 0.75 or prob <= 0.25: return 'High'\n","    if prob >= 0.65 or prob <= 0.35: return 'Medium'\n","    return 'Low'\n","\n","\n","# ── Run prediction ────────────────────────────────────────────\n","prob_a, prob_b = predict_map_winner(TEAM_A, TEAM_B, MAP, AGENTS_A, AGENTS_B)\n","winner  = TEAM_A if prob_a >= 0.5 else TEAM_B\n","conf    = confidence_label(prob_a)\n","conf_color = {'High': '#a6e3a1', 'Medium': '#f9e2af', 'Low': '#f38ba8'}[conf]\n","\n","# ── Display result ────────────────────────────────────────────\n","bar_a = int(prob_a * 300)\n","bar_b = int(prob_b * 300)\n","\n","display(HTML(f\"\"\"\n","<div style=\"font-family:monospace; background:#1e1e2e; color:#cdd6f4;\n","            padding:24px; border-radius:12px; max-width:560px; line-height:1.8\">\n","\n","  <div style=\"font-size:11px; color:#6c7086; margin-bottom:4px; letter-spacing:1px\">MAP WINNER PREDICTION</div>\n","  <div style=\"font-size:18px; font-weight:500; color:#89b4fa; margin-bottom:16px\">\n","    {MAP}\n","  </div>\n","\n","  <div style=\"display:flex; justify-content:space-between; margin-bottom:6px\">\n","    <span style=\"font-size:14px; {'color:#a6e3a1; font-weight:500' if winner==TEAM_A else 'color:#6c7086'}\">\n","      {'▶ ' if winner==TEAM_A else ''}{TEAM_A}\n","    </span>\n","    <span style=\"font-size:14px; {'color:#a6e3a1; font-weight:500' if winner==TEAM_B else 'color:#6c7086'}\">\n","      {TEAM_B}{'  ◀' if winner==TEAM_B else ''}\n","    </span>\n","  </div>\n","\n","  <div style=\"display:flex; height:10px; border-radius:5px; overflow:hidden; margin-bottom:6px\">\n","    <div style=\"width:{prob_a*100:.1f}%; background:#89b4fa;\"></div>\n","    <div style=\"width:{prob_b*100:.1f}%; background:#f38ba8;\"></div>\n","  </div>\n","\n","  <div style=\"display:flex; justify-content:space-between; font-size:20px; font-weight:500; margin-bottom:20px\">\n","    <span style=\"color:#89b4fa\">{prob_a:.1%}</span>\n","    <span style=\"color:#f38ba8\">{prob_b:.1%}</span>\n","  </div>\n","\n","  <div style=\"display:flex; justify-content:space-between; font-size:11px; color:#6c7086; margin-bottom:20px\">\n","    <div>\n","      <div>Agents: {', '.join(AGENTS_A)}</div>\n","    </div>\n","    <div 