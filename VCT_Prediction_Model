not None else '❌ NOT FOUND'\n","    print(f'  {name:<20} {status}')"]},{"cell_type":"markdown","id":"c4-md","metadata":{"id":"c4-md"},"source":["## Cell 4 - Clean & Type-cast"]},{"cell_type":"code","execution_count":8,"id":"cell-4","metadata":{"id":"cell-4","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709370811,"user_tz":-330,"elapsed":16950,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"c76a7e40-85ea-4731-c878-1e9e92814684"},"outputs":[{"output_type":"stream","name":"stdout","text":["maps_scores cleaned: (26598, 20)\n","agents_pick cleaned: (81942, 8)\n","players_stats cleaned: (365882, 27)\n","draft_phase cleaned: (18300, 9)\n","rounds_kills cleaned: (1796349, 15)\n","overview cleaned: (792616, 23)\n","\n","Cell 4 done\n"]}],"source":["def pct_to_float(series):\n","    return pd.to_numeric(\n","        series.astype(str).str.replace('%','',regex=False).str.strip(),\n","        errors='coerce') / 100\n","\n","# maps_scores — create winner\n","ms = maps_scores.copy()\n","ms = ms[ms['Map'] != 'All Maps'].copy()\n","ms['Team A Score'] = pd.to_numeric(ms['Team A Score'], errors='coerce')\n","ms['Team B Score'] = pd.to_numeric(ms['Team B Score'], errors='coerce')\n","ms['winner']       = np.where(ms['Team A Score'] > ms['Team B Score'],\n","                               ms['Team A'], ms['Team B'])\n","ms['score_diff_A'] = ms['Team A Score'] - ms['Team B Score']\n","print(f'maps_scores cleaned: {ms.shape}')\n","\n","# agents_pick\n","ap = agents_pick.copy()\n","ap['Pick Rate'] = pct_to_float(ap['Pick Rate'])\n","ap = ap[ap['Map'] == 'All Maps'].copy()\n","print(f'agents_pick cleaned: {ap.shape}')\n","\n","# players_stats — handle 2025 'Teams' column rename\n","ps = players_stats.copy()\n","for col in ['Kill, Assist, Trade, Survive %', 'Headshot %']:\n","    if col in ps.columns: ps[col] = pct_to_float(ps[col])\n","if 'Teams' in ps.columns and 'Team' not in ps.columns:\n","    ps = ps.rename(columns={'Teams': 'Team'})\n","ps = ps[ps['Map'] != 'All Maps'].copy() if 'Map' in ps.columns else ps\n","print(f'players_stats cleaned: {ps.shape}')\n","\n","# draft_phase\n","dp = draft_phase.copy()\n","print(f'draft_phase cleaned: {dp.shape}')\n","\n","# rounds_kills\n","rk = rounds_kills.copy()\n","rk = rk[rk['Map'] != 'All Maps'].copy() if 'Map' in rk.columns else rk\n","print(f'rounds_kills cleaned: {rk.shape}')\n","\n","# overview\n","ov = overview[overview['Map'] != 'All Maps'].copy() if overview is not None else None\n","if ov is not None:\n","    for col in ['Kill, Assist, Trade, Survive %', 'Headshot %']:\n","        if col in ov.columns: ov[col] = pct_to_float(ov[col])\n","    print(f'overview cleaned: {ov.shape}')\n","\n","print('\\nCell 4 done')"]},{"cell_type":"markdown","id":"c5-md","metadata":{"id":"c5-md"},"source":["## Cell 5 - Build Master Match Dataset"]},{"cell_type":"code","execution_count":9,"id":"cell-5","metadata":{"id":"cell-5","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709378398,"user_tz":-330,"elapsed":7573,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"6d16e676-d5ee-4038-b472-704757c27397"},"outputs":[{"output_type":"stream","name":"stdout","text":["Master shape: (53196, 10)\n","Win rate (should be ~0.5): 0.5000\n","_year\n","vct_2021    29006\n","vct_2022    17768\n","vct_2023     1660\n","vct_2024     2208\n","vct_2025     2554\n","Name: count, dtype: int64\n"]}],"source":["rows = []\n","for _, r in ms.iterrows():\n","    base = {\n","        'Match Name' : r['Match Name'],\n","        'Map'        : r['Map'],\n","        'Tournament' : r['Tournament'],\n","        'Stage'      : r['Stage'],\n","        'Match Type' : r['Match Type'],\n","        '_year'      : r['_year'],\n","        '_year_int'  : r['_year_int'],\n","    }\n","    for team, opp, score, opp_score, atk, defe in [\n","        (r['Team A'], r['Team B'],\n","         r['Team A Score'], r['Team B Score'],\n","         r['Team A Attacker Score'], r['Team A Defender Score']),\n","        (r['Team B'], r['Team A'],\n","         r['Team B Score'], r['Team A Score'],\n","         r['Team B Attacker Score'], r['Team B Defender Score'])\n","    ]:\n","        rows.append({**base,\n","            'Team'     : team,\n","            'Opponent' : opp,\n","            'win'      : int(r['winner'] == team)\n","        })\n","\n","master = pd.DataFrame(rows)\n","master = master.sort_values(['_year_int','Match Name','Map']).reset_index(drop=True)\n","\n","print(f'Master shape: {master.shape}')\n","print(f'Win rate (should be ~0.5): {master[\"win\"].mean():.4f}')\n","print(master['_year'].value_counts().sort_index())"]},{"cell_type":"markdown","id":"c6-md","metadata":{"id":"c6-md"},"source":["## Cell 6 - Feature Engineering: Rolling History, H2H, Map Win Rate\n","All computed using only past data — no future leakage."]},{"cell_type":"code","execution_count":10,"id":"cell-6","metadata":{"id":"cell-6","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709395120,"user_tz":-330,"elapsed":16706,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"0a324615-6188-4c44-9bd1-3950d81bd457"},"outputs":[{"output_type":"stream","name":"stdout","text":["Master after rolling features: (60048, 18)\n","\n","Cell 6 done\n"]}],"source":["def rolling_winrate(df, window=10):\n","    result = np.full(len(df), np.nan)\n","    for team, grp in df.groupby('Team'):\n","        idxs = grp.index.tolist()\n","        wins = grp['win'].values\n","        for i, idx in enumerate(idxs):\n","            past = wins[max(0,i-window):i]\n","            result[idx] = past.mean() if len(past) > 0 else np.nan\n","    return result\n","\n","def win_streak(df):\n","    result = np.zeros(len(df), dtype=int)\n","    for team, grp in df.groupby('Team'):\n","        idxs = grp.index.tolist()\n","        wins = grp['win'].values\n","        streak = 0\n","        for i, idx in enumerate(idxs):\n","            result[idx] = streak\n","            streak = streak+1 if wins[i]==1 else 0\n","    return result\n","\n","def h2h_winrate(df):\n","    result = np.full(len(df), np.nan)\n","    hist = {}\n","    for idx, row in df.iterrows():\n","        key = (row['Team'], row['Opponent'])\n","        h = hist.get(key, [])\n","        result[idx] = np.mean(h) if h else np.nan\n","        hist[key] = h + [row['win']]\n","    return result\n","\n","def map_winrate(df):\n","    result = np.full(len(df), np.nan)\n","    hist = {}\n","    for idx, row in df.iterrows():\n","        key = (row['Team'], row['Map'])\n","        h = hist.get(key, [])\n","        result[idx] = np.mean(h) if h else np.nan\n","        hist[key] = h + [row['win']]\n","    return result\n","\n","master['team_rolling_wr_10'] = rolling_winrate(master, window=10)\n","master['team_rolling_wr_5']  = rolling_winrate(master, window=5)\n","master['team_rolling_wr_20'] = rolling_winrate(master, window=20)\n","master['team_win_streak']    = win_streak(master)\n","master['h2h_win_rate']       = h2h_winrate(master)\n","master['map_specific_wr']    = map_winrate(master)\n","\n","# Opponent's rolling win rate (strength of opponent)\n","opp_wr = master[['Team','Match Name','Map','_year','team_rolling_wr_10']].copy()\n","opp_wr = opp_wr.rename(columns={'Team':'Opponent','team_rolling_wr_10':'opp_rolling_wr_10'})\n","master = master.merge(opp_wr[['Opponent','Match Name','Map','_year','opp_rolling_wr_10']],\n","                      on=['Opponent','Match Name','Map','_year'], how='left')\n","master['wr_diff'] = master['team_rolling_wr_10'] - master['opp_rolling_wr_10']\n","\n","print(f'Master after rolling features: {master.shape}')\n","print('\\nCell 6 done')"]},{"cell_type":"markdown","id":"c7-md","metadata":{"id":"c7-md"},"source":["## Cell 7 - Elo Rating System\n","Updated after every map result. Used as a pre-game feature — each team's Elo going INTO the map."]},{"cell_type":"code","execution_count":11,"id":"cell-7","metadata":{"id":"cell-7","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709400634,"user_tz":-330,"elapsed":5510,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"a4f0ca2f-86bc-43ee-f149-40edc3e910f6"},"outputs":[{"output_type":"stream","name":"stdout","text":["Elo range: 733.9 — 1514.6\n","Mean elo: 1083.3\n","\n","Top 10 teams by Elo after 2025:\n","  G2 Esports                     1437.9\n","  Paper Rex                      1386.6\n","  Mega Minors                    1310.1\n","  DRX                            1285.7\n","  FNATIC                         1282.3\n","  KRÜ Esports                    1270.7\n","  Rex Regum Qeon                 1270.3\n","  Evil Geniuses                  1270.2\n","  Cloud9                         1259.0\n","  BBL Esports                    1258.9\n","\n","Cell 7 done\n"]}],"source":["K = 32       # K-factor: how much each result shifts ratings\n","BASE_ELO = 1000\n","\n","def expected_score(ra, rb):\n","    return 1 / (1 + 10 ** ((rb - ra) / 400))\n","\n","def compute_elo(df):\n","    \"\"\"\n","    Processes rows in chronological order.\n","    Stores the ELO going INTO each map (before the result is known).\n","    \"\"\"\n","    elo_store = {}  # team -> current elo\n","    elo_before = np.full(len(df), np.nan)\n","    opp_elo_before = np.full(len(df), np.nan)\n","\n","    # Process unique maps in order (each map has 2 rows: Team A and Team B)\n","    # Group by match+map to process both teams together\n","    processed = set()\n","    for idx, row in df.iterrows():\n","        key = (row['Match Name'], row['Map'], row['_year'])\n","        team = row['Team']\n","        opp  = row['Opponent']\n","\n","        # Store current elo before this map\n","        elo_before[idx]     = elo_store.get(team, BASE_ELO)\n","        opp_elo_before[idx] = elo_store.get(opp,  BASE_ELO)\n","\n","        # Only update elo once per unique map (not twice for both rows)\n","        if key not in processed:\n","            processed.add(key)\n","            ra = elo_store.get(team, BASE_ELO)\n","            rb = elo_store.get(opp,  BASE_ELO)\n","            ea = expected_score(ra, rb)\n","            sa = row['win']  # 1 if team won, 0 if lost\n","            elo_store[team] = ra + K * (sa - ea)\n","            elo_store[opp]  = rb + K * ((1 - sa) - (1 - ea))\n","\n","    return elo_before, opp_elo_before\n","\n","master['elo'], master['opp_elo'] = compute_elo(master)\n","master['elo_diff'] = master['elo'] - master['opp_elo']\n","\n","print(f'Elo range: {master[\"elo\"].min():.1f} — {master[\"elo\"].max():.1f}')\n","print(f'Mean elo: {master[\"elo\"].mean():.1f}')\n","\n","# Top 10 teams by final Elo (2025)\n","final_elos = {}\n","for _, row in master[master['_year_int']==2025].iterrows():\n","    final_elos[row['Team']] = row['elo']\n","top10 = sorted(final_elos.items(), key=lambda x: x[1], reverse=True)[:10]\n","print('\\nTop 10 teams by Elo after 2025:')\n","for team, elo in top10:\n","    print(f'  {team:<30} {elo:.1f}')\n","\n","print('\\nCell 7 done')"]},{"cell_type":"markdown","id":"c8-md","metadata":{"id":"c8-md"},"source":["## Cell 8 - Agent Meta Score\n","How well each team's historical agent picks align with the current year's meta."]},{"cell_type":"code","execution_count":12,"id":"cell-8","metadata":{"id":"cell-8","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709401281,"user_tz":-330,"elapsed":561,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"a3e45dbf-1bb7-478a-add0-0a0877e63758"},"outputs":[{"output_type":"stream","name":"stdout","text":["Master after meta features: (60048, 27)\n","\n","Cell 8 done\n"]}],"source":["# Meta pick rate per agent per year\n","meta = (ap.groupby(['Agent','_year'])['Pick Rate']\n","        .mean().reset_index()\n","        .rename(columns={'Pick Rate':'meta_pick_rate'}))\n","\n","# Team agent features (tournament level — no Match Name)\n","ta = teams_agents[teams_agents['Map'] != 'All Maps'].copy()\n","ta = ta.merge(meta[['Agent','_year','meta_pick_rate']], on=['Agent','_year'], how='left')\n","\n","team_meta = (ta.groupby(['Team','Map','_year'])\n","             .agg(meta_score=('meta_pick_rate','mean'),\n","                  agent_diversity=('Agent','nunique'),\n","                  team_map_wins=('Total Wins By Map','sum'),\n","                  team_map_losses=('Total Loss By Map','sum')\n","             ).reset_index())\n","team_meta['team_map_wr_hist'] = (\n","    team_meta['team_map_wins'] /\n","    (team_meta['team_map_wins'] + team_meta['team_map_losses']).replace(0, np.nan))\n","team_meta['team_map_total_played'] = team_meta['team_map_wins'] + team_meta['team_map_losses']\n","\n","master = master.merge(team_meta, on=['Team','Map','_year'], how='left')\n","print(f'Master after meta features: {master.shape}')\n","print('\\nCell 8 done')"]},{"cell_type":"markdown","id":"c9-md","metadata":{"id":"c9-md"},"source":["## Cell 9 - Player Stats: Rolling Historical Performance\n","Historical ACS, KD, ADR, KAST per team — averaged across players, computed from past matches only."]},{"cell_type":"code","execution_count":13,"id":"cell-9","metadata":{"id":"cell-9","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709401313,"user_tz":-330,"elapsed":19,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"b2bef55e-998e-4d9d-eba3-205553e823c1"},"outputs":[{"output_type":"stream","name":"stdout","text":["players_stats missing Match Name/Map/Team — skipping player features\n","\n","Cell 9 done\n"]}],"source":["# Aggregate players_stats to team level per match per map\n","ps_cols = {\n","    'Average Combat Score'             : 'avg_acs',\n","    'Kills - Deaths (KD)'              : 'avg_kd',\n","    'Average Damage Per Round'         : 'avg_adr',\n","    'Kill, Assist, Trade, Survive %'   : 'avg_kast',\n","    'Headshot %'                       : 'avg_hs',\n","    'First Kills'                      : 'avg_fk',\n","    'First Deaths'                     : 'avg_fd',\n","}\n","\n","# Keep only columns that exist\n","agg_dict = {orig: (rename, 'mean')\n","            for orig, rename in ps_cols.items() if orig in ps.columns}\n","\n","group_cols = ['Match Name','Map','Team','_year','_year_int']\n","group_cols = [c for c in group_cols if c in ps.columns]\n","\n","if 'Match Name' in ps.columns and 'Map' in ps.columns and 'Team' in ps.columns:\n","    ps_team = (ps[ps['Map'] != 'All Maps']\n","               .groupby(['Match Name','Map','Team','_year'])\n","               .agg(**{v: (k, 'mean') for k, v in ps_cols.items() if k in ps.columns})\n","               .reset_index())\n","    ps_team['fk_diff'] = ps_team.get('avg_fk', pd.Series(dtype=float)) - \\\n","                          ps_team.get('avg_fd', pd.Series(dtype=float))\n","\n","    # Now compute ROLLING historical averages per team\n","    # Sort chronologically, then for each row take the mean of all PRIOR rows for that team\n","    ps_team = ps_team.sort_values(['_year','Match Name','Map']).reset_index(drop=True)\n","    stat_cols = [c for c in ['avg_acs','avg_kd','avg_adr','avg_kast','avg_hs','fk_diff']\n","                 if c in ps_team.columns]\n","\n","    rolling_stats = {col: np.full(len(ps_team), np.nan) for col in stat_cols}\n","    team_hist = {col: {} for col in stat_cols}\n","\n","    for idx, row in ps_team.iterrows():\n","        team = row['Team']\n","        for col in stat_cols:\n","            hist = team_hist[col].get(team, [])\n","            rolling_stats[col][idx] = np.mean(hist[-10:]) if hist else np.nan\n","            if pd.notna(row.get(col, np.nan)):\n","                team_hist[col][team] = hist + [row[col]]\n","\n","    for col in stat_cols:\n","        ps_team[f'hist_{col}'] = rolling_stats[col]\n","\n","    hist_cols = [f'hist_{c}' for c in stat_cols]\n","    ps_merge = ps_team[['Match Name','Map','Team','_year'] + hist_cols]\n","    master = master.merge(ps_merge, on=['Match Name','Map','Team','_year'], how='left')\n","    print(f'Master after player history features: {master.shape}')\n","    print(f'Historical stat cols added: {hist_cols}')\n","else:\n","    print('players_stats missing Match Name/Map/Team — skipping player features')\n","    hist_cols = []\n","\n","print('\\nCell 9 done')"]},{"cell_type":"markdown","id":"c10-md","metadata":{"id":"c10-md"},"source":["## Cell 10 - Draft Phase: Map Ban/Pick Tendencies\n","How often each team bans or picks each map — encodes strategic preferences."]},{"cell_type":"code","execution_count":14,"id":"cell-10","metadata":{"id":"cell-10","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709401444,"user_tz":-330,"elapsed":128,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"14d0bca7-1cf1-40b1-b82a-e27205079294"},"outputs":[{"output_type":"stream","name":"stdout","text":["Master after draft features: (60048, 32)\n","Draft features added: ban_rate, pick_rate, map_preference, opp_map_preference, map_preference_diff\n","\n","Cell 10 done\n"]}],"source":["if dp is not None and 'Action' in dp.columns:\n","    # Count bans and picks per team per map per year\n","    bans  = dp[dp['Action']=='ban'].groupby(['Team','Map','_year']).size().reset_index(name='ban_count')\n","    picks = dp[dp['Action']=='pick'].groupby(['Team','Map','_year']).size().reset_index(name='pick_count')\n","\n","    # Total actions per team per year (to normalize)\n","    total_actions = dp.groupby(['Team','_year']).size().reset_index(name='total_actions')\n","\n","    draft_feats = bans.merge(picks, on=['Team','Map','_year'], how='outer').fillna(0)\n","    draft_feats = draft_feats.merge(total_actions, on=['Team','_year'], how='left')\n","    draft_feats['ban_rate']  = draft_feats['ban_count']  / draft_feats['total_actions'].replace(0, np.nan)\n","    draft_feats['pick_rate'] = draft_feats['pick_count'] / draft_feats['total_actions'].replace(0, np.nan)\n","\n","    # High ban rate = team wants to avoid this map (weak map)\n","    # High pick rate = team wants to play this map (strong map)\n","    draft_feats['map_preference'] = draft_feats['pick_rate'] - draft_feats['ban_rate']\n","\n","    master = master.merge(\n","        draft_feats[['Team','Map','_year','ban_rate','pick_rate','map_preference']],\n","        on=['Team','Map','_year'], how='left')\n","\n","    # Also add opponent's map preference (negative = they don't want this map)\n","    opp_draft = draft_feats[['Team','Map','_year','map_preference']].copy()\n","    opp_draft = opp_draft.rename(columns={'Team':'Opponent','map_preference':'opp_map_preference'})\n","    master = master.merge(\n","        opp_draft[['Opponent','Map','_year','opp_map_preference']],\n","        on=['Opponent','Map','_year'], how='left')\n","    master['map_preference_diff'] = master['map_preference'] - master['opp_map_preference']\n","\n","    print(f'Master after draft features: {master.shape}')\n","    print('Draft features added: ban_rate, pick_rate, map_preference, opp_map_preference, map_preference_diff')\n","else:\n","    print('draft_phase not available — skipping')\n","\n","print('\\nCell 10 done')"]},{"cell_type":"markdown","id":"c11-md","metadata":{"id":"c11-md"},"source":["## Cell 11 - First Blood Rate from rounds_kills\n","Historical rate at which each team gets the first kill in a round."]},{"cell_type":"code","execution_count":15,"id":"cell-11","metadata":{"id":"cell-11","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709408217,"user_tz":-330,"elapsed":6768,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"a873a41c-3323-4cbf-d002-1d9a69ad9947"},"outputs":[{"output_type":"stream","name":"stdout","text":["Master after first blood features: (60048, 33)\n","\n","Cell 11 done\n"]}],"source":["if rk is not None and 'Eliminator Team' in rk.columns and 'Round Number' in rk.columns:\n","    # First kill in each round = the kill with the lowest kill order\n","    # rounds_kills has one row per kill — identify first kill per round\n","    rk_sorted = rk.sort_values(['Match Name','Map','Round Number','_year'])\n","\n","    # First kill per round\n","    first_kills = (rk_sorted\n","                   .groupby(['Match Name','Map','Round Number','_year'])\n","                   .first()\n","                   .reset_index()[['Match Name','Map','Round Number','_year',\n","                                   'Eliminator Team','Eliminated Team']])\n","\n","    # Count first kills per team per match per map\n","    fk_agg = (first_kills.groupby(['Match Name','Map','Eliminator Team','_year'])\n","              .size().reset_index(name='first_kills_count')\n","              .rename(columns={'Eliminator Team':'Team'}))\n","\n","    # Total rounds per match per map (to normalize)\n","    total_rounds = (first_kills.groupby(['Match Name','Map','_year'])\n","                    .size().reset_index(name='total_rounds'))\n","\n","    fk_agg = fk_agg.merge(total_rounds, on=['Match Name','Map','_year'], how='left')\n","    fk_agg['first_kill_rate'] = fk_agg['first_kills_count'] / fk_agg['total_rounds'].replace(0,np.nan)\n","\n","    # Now compute rolling historical first kill rate per team (past matches only)\n","    fk_agg = fk_agg.sort_values(['_year','Match Name','Map']).reset_index(drop=True)\n","    hist_fkr = np.full(len(fk_agg), np.nan)\n","    fkr_hist = {}\n","    for idx, row in fk_agg.iterrows():\n","        team = row['Team']\n","        h = fkr_hist.get(team, [])\n","        hist_fkr[idx] = np.mean(h[-10:]) if h else np.nan\n","        if pd.notna(row['first_kill_rate']):\n","            fkr_hist[team] = h + [row['first_kill_rate']]\n","    fk_agg['hist_first_kill_rate'] = hist_fkr\n","\n","    master = master.merge(\n","        fk_agg[['Match Name','Map','Team','_year','hist_first_kill_rate']],\n","        on=['Match Name','Map','Team','_year'], how='left')\n","    print(f'Master after first blood features: {master.shape}')\n","else:\n","    print('rounds_kills missing required columns — skipping')\n","\n","print('\\nCell 11 done')"]},{"cell_type":"markdown","id":"c12-md","metadata":{"id":"c12-md"},"source":["## Cell 12 - Recency Weights & Feature Selection"]},{"cell_type":"code","execution_count":16,"id":"cell-12","metadata":{"id":"cell-12","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709408304,"user_tz":-330,"elapsed":83,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"1ca77d44-896a-4eaa-89d2-a7b71a65ede3"},"outputs":[{"output_type":"stream","name":"stdout","text":["Total pre-game features: 26\n","Features: ['map_encoded', '_year_int', 'is_playoffs', 'team_rolling_wr_10', 'team_rolling_wr_5', 'team_rolling_wr_20', 'team_win_streak', 'opp_rolling_wr_10', 'wr_diff', 'h2h_win_rate', 'map_specific_wr', 'team_map_wins', 'team_map_losses', 'team_map_wr_hist', 'team_map_total_played', 'elo', 'opp_elo', 'elo_diff', 'meta_score', 'agent_diversity', 'ban_rate', 'pick_rate', 'map_preference', 'opp_map_preference', 'map_preference_diff', 'hist_first_kill_rate']\n","\n","Missing rate per feature (top 10):\n","map_preference_diff    0.5980\n","ban_rate               0.4820\n","map_preference         0.4820\n","pick_rate              0.4820\n","opp_map_preference     0.4820\n","h2h_win_rate           0.3340\n","hist_first_kill_rate   0.2810\n","map_specific_wr        0.2400\n","wr_diff                0.1200\n","opp_rolling_wr_10      0.0670\n","dtype: float64\n","\n","Cell 12 done\n"]}],"source":["# Recency weights\n","DECAY = 0.6\n","master['sample_weight'] = master['_year_int'].apply(\n","    lambda y: DECAY ** (2023 - y) if y <= 2023 else 1.0)\n","\n","# Map encoding\n","map_encoder = LabelEncoder()\n","master['map_encoded'] = map_encoder.fit_transform(master['Map'].fillna('Unknown'))\n","\n","# Stage encoding (playoffs vs group stage)\n","master['is_playoffs'] = master['Stage'].str.lower().str.contains(\n","    'playoff|final|semi|quarter', na=False).astype(int)\n","\n","# ── FEATURE COLS — PRE-GAME ONLY (no post-game stats) ────────\n","FEATURE_COLS = [\n","    # Context\n","    'map_encoded',\n","    '_year_int',\n","    'is_playoffs',\n","    # Team momentum\n","    'team_rolling_wr_10',\n","    'team_rolling_wr_5',\n","    'team_rolling_wr_20',\n","    'team_win_streak',\n","    # Opponent context\n","    'opp_rolling_wr_10',\n","    'wr_diff',\n","    # H2H\n","    'h2h_win_rate',\n","    # Map-specific history\n","    'map_specific_wr',\n","    'team_map_wins',\n","    'team_map_losses',\n","    'team_map_wr_hist',\n","    'team_map_total_played',\n","    # Elo\n","    'elo',\n","    'opp_elo',\n","    'elo_diff',\n","    # Agent meta\n","    'meta_score',\n","    'agent_diversity',\n","    # Draft tendencies\n","    'ban_rate',\n","    'pick_rate',\n","    'map_preference',\n","    'opp_map_preference',\n","    'map_preference_diff',\n","    # Historical player performance\n","    'hist_avg_acs',\n","    'hist_avg_kd',\n","    'hist_avg_adr',\n","    'hist_avg_kast',\n","    'hist_avg_hs',\n","    'hist_fk_diff',\n","    # First blood\n","    'hist_first_kill_rate',\n","]\n","\n","# Keep only cols that actually exist in master\n","FEATURE_COLS = [c for c in FEATURE_COLS if c in master.columns]\n","print(f'Total pre-game features: {len(FEATURE_COLS)}')\n","print(f'Features: {FEATURE_COLS}')\n","\n","# Missing rate per feature\n","missing = master[FEATURE_COLS].isna().mean().sort_values(ascending=False)\n","print('\\nMissing rate per feature (top 10):')\n","print(missing.head(10).round(3))\n","print('\\nCell 12 done')"]},{"cell_type":"markdown","id":"c13-md","metadata":{"id":"c13-md"},"source":["## Cell 13 - Time-Based Train / Val / Test Split"]},{"cell_type":"code","execution_count":17,"id":"cell-13","metadata":{"id":"cell-13","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709408369,"user_tz":-330,"elapsed":62,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"cfc70356-8f6e-4a2f-9b8d-7afe345f6daf"},"outputs":[{"output_type":"stream","name":"stdout","text":["Train (2021-2023): 54,170 rows  win_rate=0.500\n","Val   (2024)     : 2,784 rows  win_rate=0.500\n","Test  (2025)     : 3,094 rows  win_rate=0.500\n","\n","Feature matrix shapes:\n","  Train: (54170, 26)  Val: (2784, 26)  Test: (3094, 26)\n","\n","Cell 13 done\n"]}],"source":["master = master.dropna(subset=['win']).copy()\n","\n","train_df = master[master['_year_int'] <= 2023].copy()\n","val_df   = master[master['_year_int'] == 2024].copy()\n","test_df  = master[master['_year_int'] == 2025].copy()\n","\n","print(f'Train (2021-2023): {len(train_df):,} rows  win_rate={train_df[\"win\"].mean():.3f}')\n","print(f'Val   (2024)     : {len(val_df):,} rows  win_rate={val_df[\"win\"].mean():.3f}')\n","print(f'Test  (2025)     : {len(test_df):,} rows  win_rate={test_df[\"win\"].mean():.3f}')\n","\n","X_train = train_df[FEATURE_COLS]\n","y_train = train_df['win'].values\n","w_train = train_df['sample_weight'].values\n","X_val   = val_df[FEATURE_COLS]\n","y_val   = val_df['win'].values\n","X_test  = test_df[FEATURE_COLS]\n","y_test  = test_df['win'].values\n","\n","print(f'\\nFeature matrix shapes:')\n","print(f'  Train: {X_train.shape}  Val: {X_val.shape}  Test: {X_test.shape}')\n","print('\\nCell 13 done')"]},{"cell_type":"markdown","id":"c14-md","metadata":{"id":"c14-md"},"source":["## Cell 14 - Train All 5 Models + Ensemble\n","All trained with recency weights. Ensemble combines XGBoost + LightGBM + CatBoost."]},{"cell_type":"code","execution_count":18,"id":"cell-14","metadata":{"id":"cell-14","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776709458694,"user_tz":-330,"elapsed":50323,"user":{"displayName":"Pranav V S","userId":"07627724741023734392"}},"outputId":"134192b2-b474-42b5-c2b5-3d60abe1c900"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","ALL MODELS (pre-game only, recency weighted)\n","======================================================================\n","  Logistic Regression             Val: Acc=0.704 AUC=0.776 | Test: Acc=0.718 AUC=0.799\n","  Random Forest                   Val: Acc=0.698 AUC=0.767 | Test: Acc=0.706 AUC=0.790\n","  XGBoost                         Val: Acc=0.709 AUC=0.793 | Test: Acc=0.720 AUC=0.810\n","  LightGBM                        Val: Acc=0.711 AUC=0.792 | Test: Acc=0.720 AUC=0.809\n","  CatBoost                        Val: Acc=0.708 AUC=0.794 | Test: Acc=0.725 AUC=0.808\n","\n","  Ensemble (XGB+LGBM+Cat)         Val: Acc=0.713 AUC=0.795 | Test: Acc=0.723 AUC=0.811\n","\n","Cell 14 done\n"]}],"source":["def make_pipe(model):\n","    return Pipeline([\n","        ('imputer', SimpleImputer(strategy='median')),\n","        ('scaler',  StandardScaler()),\n","        ('model',   model)\n","    ])\n","\n","def evaluate(name, pipe, X_tr, y_tr, w_tr, X_v, y_v, X_te, y_te,\n","             use_weights=True, is_cat=False, imputer=None):\n","    if is_cat:\n","        imp = SimpleImputer(strategy='median')\n","        Xtr_imp = imp.fit_transform(X_tr)\n","        Xv_imp  = imp.transform(X_v)\n","        Xte_imp = imp.transform(X_te)\n","        if use_weights:\n","            pipe.fit(Xtr_imp, y_tr, sample_weight=w_tr)\n","        else:\n","            pipe.fit(Xtr_imp, y_tr)\n","        get_prob  = lambda X: pipe.predict_proba(X)[:,1]\n","        get_pred  = lambda X: pipe.predict(X)\n","        Xv_use, Xte_use = Xv_imp, Xte_imp\n","        pipe._p3_imputer = imp\n","    else:\n","        fp = {'model__sample_weight': w_tr} if use_weights else {}\n","        pipe.fit(X_tr, y_tr, **fp)\n","        get_prob  = lambda X: pipe.predict_proba(X)[:,1]\n","        get_pred  = lambda X: pipe.predict(X)\n","        Xv_use, Xte_use = X_v, X_te\n","\n","    res = {}\n","    for sname, X, y in [('val', Xv_use, y_v), ('test', Xte_use, y_te)]:\n","        preds = get_pred(X)\n","        probs = get_prob(X)\n","        res[sname] = {\n","            'acc'  : accuracy_score(y, preds),\n","            'auc'  : roc_auc_score(y, probs),\n","            'brier': brier_score_loss(y, probs),\n","            'probs': probs,\n","            'preds': preds,\n","        }\n","    print(f'  {name:<30}  '\n","          f'Val: Acc={res[\"val\"][\"acc\"]:.3f} AUC={res[\"val\"][\"auc\"]:.3f} | '\n","          f'Test: Acc={res[\"test\"][\"acc\"]:.3f} AUC={res[\"test\"][\"auc\"]:.3f}')\n","    return pipe, res\n","\n","trained = {}\n","all_results = []\n","test_probs_for_ensemble = {}\n","val_probs_for_ensemble  = {}\n","\n","print('='*70)\n","print('ALL MODELS (pre-game only, recency weighted)')\n","print('='*70)\n","\n","MODELS = [\n","    ('Logistic Regression',\n","     make_pipe(LogisticRegression(max_iter=1000, C=0.1)),\n","     False, False),\n","\n","    ('Random Forest',\n","     make_pipe(RandomForestClassifier(\n","         n_estimators=300, max_depth=8, min_samples_leaf=15,\n","         random_state=42, n_jobs=-1)),\n","     True, False),\n","\n","    ('XGBoost',\n","     make_pipe(XGBClassifier(\n","         n_estimators=400, max_depth=5, learning_rate=0.05,\n","         subsample=0.8, colsample_bytree=0.8, min_child_weight=10,\n","         eval_metric='logloss', random_state=42, verbosity=0)),\n","     True, False),\n","\n","    ('LightGBM',\n","     make_pipe(LGBMClassifier(\n","         n_estimators=400, max_depth=6, learning_rate=0.05,\n","         num_leaves=31, subsample=0.8, colsample_bytree=0.8,\n","         min_child_samples=20, random_state=42, verbose=-1)),\n","     True, False),\n","\n","    ('CatBoost',\n","     CatBoostClassifier(\n","         iterations=400, depth=6, learning_rate=0.05,\n","         l2_leaf_reg=3, random_seed=42, verbose=0),\n","     True, True),\n","]\n","\n","for name, pipe, supports_w, is_cat in MODELS:\n","    p, res = evaluate(name, pipe,\n","                      X_train, y_train, w_train,\n","                      X_val, y_val, X_test, y_test,\n","                      use_weights=supports_w, is_cat=is_cat)\n","    trained[name] = (p, is_cat)\n","    for split, metrics in res.items():\n","        all_results.append({'model': name, 'split': split,\n","                            'acc': metrics['acc'], 'auc': metrics['auc'],\n","                            'brier': metrics['brier']})\n","    # Store probs for ensemble\n","    if name in ['XGBoost','LightGBM','CatBoost']:\n","        test_probs_for_ensemble[name] = res['test']['probs']\n","        val_probs_for_ensemble[name]  = res['val']['probs']\n","\n","# ── Ensemble: average probabilities from XGB + LGBM + CatBoost ──\n","print()\n","ens_val_probs  = np.mean(list(val_probs_for_ensemble.values()),  axis=0)\n","ens_test_probs = np.mean(list(test_probs_for_ensemble.values()), axis=0)\n","ens_val_preds  = (ens_val_probs  >= 0.5).astype(int)\n","ens_test_preds = (ens_test_probs >= 0.5).astype(int)\n","\n","ens_res = {\n","    'val' : {'acc': accuracy_score(y_val,  ens_val_preds),\n","             'auc': roc_auc_score(y_val,   ens_val_probs),\n","             'brier': brier_score_loss(y_val,  ens_val_probs),\n","             'probs': ens_val_probs, 'preds': ens_val_preds},\n","    'test': {'acc': accuracy_score(y_test, ens_test_preds),\n","             'auc': roc_auc_score(y_test,  ens_test_probs),\n","             'brier': brier_score_loss(y_test, ens_test_probs),\n","             'probs': ens_test_probs, 'preds': ens_test_preds}\n","}\n","print(f'  {\"Ensemble (XGB+LGBM+Cat)\":<30}  '\n","      f'Val: Acc={ens_res[\"val\"][\"acc\"]:.3f} AUC={ens_res[\"val\"][\"auc\"]:.3f} | '\n","      f'Test: Acc={ens_res[\"test\"][\"acc\"]:.3f} AUC={ens_res[\"test\"][\"auc\"